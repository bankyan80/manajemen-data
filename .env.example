# Turso Database (wajib)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Vercel Blob Storage (untuk upload dokumen pegawai)
# Buat token: https://vercel.com/docs/storage/vercel-blob/quickstart
BLOB_READ_WRITE_TOKEN=

# Google Sheets - Service Account (untuk sinkron rekap)
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=

# NextAuth (wajib)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-min-32-chars

# App
APP_NAME=Manajemen Satu Data
APP_REGION=Kecamatan Lemahabang
APP_YEAR=2026
